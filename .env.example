APP_NAME=reliable-crypto-bot
ENVIRONMENT=dev
EXCHANGE=binance
POLL_INTERVAL_SECONDS=5
PAPER_INITIAL_CASH=10000

TRADING__MODE=paper
TRADING__LIVE_TRADING_ENABLED=false
TRADING__KILL_SWITCH_ENABLED=true
TRADING__CIRCUIT_BREAKER_FAILURES=3

STRATEGY__NAME=ema_crossover
STRATEGY__TIMEFRAME=1m
STRATEGY__SYMBOL=BTC/USDT

RISK__MAX_RISK_PER_TRADE=0.01
RISK__MAX_DAILY_LOSS_PCT=0.03
RISK__MAX_DRAWDOWN_PCT=0.2
RISK__MAX_CONCURRENT_POSITIONS=3
RISK__MIN_CONFIDENCE=0.55
RISK__MAX_SPREAD_BPS=20

BACKTEST__INITIAL_CASH=10000
BACKTEST__FEE_RATE=0.001
BACKTEST__SLIPPAGE_BPS=5
BACKTEST__SPREAD_BPS=2
BACKTEST__LATENCY_BARS=1
BACKTEST__PARTIAL_FILL_RATIO=1.0

STORAGE__SQLITE_PATH=var/trading_platform.db
STORAGE__PERSIST_SIGNALS=true
STORAGE__PERSIST_TRADES=true
STORAGE__PERSIST_RUNS=true

EXECUTION__ORDER_TIMEOUT_SECONDS=8
EXECUTION__RETRY_ATTEMPTS=2

# Keep these unset unless you intentionally enable live trading.
API_KEY=
API_SECRET=
